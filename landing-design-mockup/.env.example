# Скопируйте в .env при локальной работе с PostgreSQL + API.
# Обычный `npm run dev` использует IndexedDB — DATABASE_URL не нужен.

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/car_notes

# Включить HTTP API вместо IndexedDB в dev (нужны DATABASE_URL и `npm run dev:api`):
# VITE_USE_HTTP_DB=true

# Принудительно без SSL к локальному Postgres (если нужно):
# DATABASE_SSL=0
